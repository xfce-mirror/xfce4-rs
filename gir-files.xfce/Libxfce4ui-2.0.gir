               line="268">shell command line to execute.</doc>
          <type name="utf8" c:type="const gchar*"/>
        </parameter>
        <parameter name="working_directory" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-execute.c"
