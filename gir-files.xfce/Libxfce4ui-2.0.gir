                 line="8274">A #XfceIconView.</doc>
            <type name="IconView" c:type="XfceIconView*"/>
          </instance-parameter>
          <parameter name="reorderable" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-icon-view.c"
                 line="8275">%TRUE, if the list of items can be reordered.</doc>
            <type name="gboolean" c:type="gboolean"/>
          </parameter>
        </parameters>
      </method>
