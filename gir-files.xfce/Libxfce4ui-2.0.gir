                 line="1871">An #XfceSMClient</doc>
            <type name="SMClient" c:type="XfceSMClient*"/>
          </instance-parameter>
          <parameter name="desktop_file" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-sm-client.c"
                 line="1872">The path to the application's .desktop file</doc>
            <type name="utf8" c:type="const gchar*"/>
          </parameter>
        </parameters>
      </method>
