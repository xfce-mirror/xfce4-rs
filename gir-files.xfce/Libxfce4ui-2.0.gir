                   version="4.21.0">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-cell-renderer-icon.c"
             line="577">Creates a new #XfceCellRendererIcon. Adjust rendering parameters using object properties,
which can be set globally via g_object_set(). Also, with #GtkCellLayout and
#GtkTreeViewColumn, you can bind a property to a value in a #GtkTreeModel. For example
you can bind the XfceCellRendererIcon:icon property on the
cell renderer to an icon name in the model, thus rendering a different icon in each row
of the #GtkTreeView.</doc>
        <source-position filename="libxfce4ui/xfce-cell-renderer-icon.h"
                         line="35"/>
        <return-value transfer-ownership="full">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-cell-renderer-icon.c"
               line="587">the newly allocated #XfceCellRendererIcon.</doc>
          <type name="Gtk.CellRenderer" c:type="GtkCellRenderer*"/>
        </return-value>
      </constructor>
      <property name="follow-state"
                version="4.21.0"
                writable="1"
                construct="1"
                transfer-ownership="none"
                default-value="TRUE">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-cell-renderer-icon.c"
             line="138">Specifies whether the icon renderer should render icon based on the
selection state of the items. This is necessary for #XfceIconView,
which doesn't draw any item state indicators itself.</doc>
        <type name="gboolean" c:type="gboolean"/>
      </property>
      <property name="gicon"
                version="4.21.0"
                writable="1"
                transfer-ownership="none">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-cell-renderer-icon.c"
             line="177">The #GIcon to render. May also be %NULL in which case no icon will be
rendered for the cell.

Currently only #GThemedIcon&lt;!----&gt;s are supported which are loaded
using the current icon theme.</doc>
        <type name="Gio.Icon"/>
      </property>
      <property name="icon"
                version="4.21.0"
                writable="1"
                transfer-ownership="none"
                default-value="NULL">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-cell-renderer-icon.c"
             line="155">The name of the themed icon to render or an absolute path to an image file
to render. May also be %NULL in which case no icon will be rendered for the
cell.

Image files are loaded via the thumbnail database, creating a thumbnail
as necessary. The thumbnail database is also used to load scalable icons
in the icon theme, because loading scalable icons is quite expensive
these days.</doc>
        <type name="utf8" c:type="gchar*"/>
      </property>
      <property name="size"
                version="4.21.0"
                writable="1"
                construct="1"
                transfer-ownership="none"
                default-value="48">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-cell-renderer-icon.c"
             line="196">The size in pixel at which to render the icon. This is also the fixed
size that the renderer will request no matter if the actual icons are
smaller than this size.

This improves the performance of the layouting in the icon and tree
view, because during the layouting phase no icons will need to be
loaded, but the icons will only be loaded when they need to be rendered,
i.e. the view scrolls to the cell.</doc>
        <type name="gint" c:type="gint"/>
      </property>
    </class>
