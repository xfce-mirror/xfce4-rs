                   nullable="1"
                   allow-none="1">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-dialogs.c"
               line="139">name of the component opening the help page or %NULL. If the
             value is %NULL the target will be the main page of the
             documentation website.</doc>
          <type name="utf8" c:type="const gchar*"/>
        </parameter>
        <parameter name="page"
