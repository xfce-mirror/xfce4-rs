      <method name="get_icon"
              c:identifier="xfce_icon_chooser_dialog_get_icon"
              version="4.21.0">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-icon-chooser-dialog.c"
             line="664">Returns the currently selected icon for the @dialog. The selected icon can be either
a named icon (from the active icon theme) or the absolute path to an image file in the file system.
You can distinguish between those two icon types using the g_path_is_absolute() function. If no
icon is currently selected, %NULL will be returned.

The caller is responsible to free the returned string using g_free() when no longer needed.</doc>
        <source-position filename="libxfce4ui/xfce-icon-chooser-dialog.h"
                         line="41"/>
        <return-value transfer-ownership="full" nullable="1">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-icon-chooser-dialog.c"
               line="675">the currently selected icon for @dialog or %NULL if no icon is selected.</doc>
