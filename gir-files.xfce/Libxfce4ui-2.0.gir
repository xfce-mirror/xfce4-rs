      <method name="scroll_to_path"
              c:identifier="xfce_icon_view_scroll_to_path"
              version="4.21.0">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-icon-view.c"
             line="6551">Moves the alignments of @icon_view to the position specified by @path.
@row_align determines where the row is placed, and @col_align determines where
@column is placed.  Both are expected to be between 0.0 and 1.0.
0.0 means left/top alignment, 1.0 means right/bottom alignment, 0.5 means center.

If @use_align is %FALSE, then the alignment arguments are ignored, and the
tree does the minimum amount of work to scroll the item onto the screen.
This means that the item will be scrolled to the edge closest to its current
position.  If the item is currently visible on the screen, nothing is done.

This function only works if the model is set, and @path is a valid row on the
model.  If the model changes before the @tree_view is realized, the centered
path will be modified to reflect this change.</doc>
        <source-position filename="libxfce4ui/xfce-icon-view.h" line="289"/>
        <return-value transfer-ownership="none">
          <type name="none" c:type="void"/>
        </return-value>
        <parameters>
          <instance-parameter name="icon_view" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-icon-view.c"
                 line="6553">A #XfceIconView.</doc>
            <type name="IconView" c:type="XfceIconView*"/>
          </instance-parameter>
          <parameter name="path" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-icon-view.c"
                 line="6554">The path of the item to move to.</doc>
            <type name="Gtk.TreePath" c:type="GtkTreePath*"/>
          </parameter>
          <parameter name="use_align" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-icon-view.c"
                 line="6555">whether to use alignment arguments, or %FALSE.</doc>
            <type name="gboolean" c:type="gboolean"/>
          </parameter>
          <parameter name="row_align" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-icon-view.c"
                 line="6556">The vertical alignment of the item specified by @path.</doc>
            <type name="gfloat" c:type="gfloat"/>
          </parameter>
          <parameter name="col_align" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libxfce4ui/xfce-icon-view.c"
                 line="6557">The horizontal alignment of the item specified by @column.</doc>
            <type name="gfloat" c:type="gfloat"/>
          </parameter>
        </parameters>
      </method>
