    <function name="gtk_url_about_dialog_hook"
              c:identifier="xfce_gtk_url_about_dialog_hook"
              version="4.21.0">
      <doc xml:space="preserve"
           filename="libxfce4ui/xfce-gtk-extensions.c"
           line="1253">This is a convenience function, which can be registered with #GtkAboutDialog,
to open links clicked by the user in #GtkAboutDialog&lt;!----&gt;s.

All you need to do is to register this hook with gtk_about_dialog_set_url_hook()
and gtk_about_dialog_set_email_hook(). This can be done prior to calling
gtk_show_about_dialog(), for example:

&lt;informalexample&gt;&lt;programlisting&gt;
static void show_about_dialog (void)
{

  gtk_show_about_dialog (.....);
}
&lt;/programlisting&gt;&lt;/informalexample&gt;

This function is not needed when you use Gtk 2.18 or later, because from
that version this is implemented by default.</doc>
      <source-position filename="libxfce4ui/xfce-gtk-extensions.h" line="231"/>
      <return-value transfer-ownership="none">
        <type name="none" c:type="void"/>
      </return-value>
      <parameters>
        <parameter name="about_dialog" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-gtk-extensions.c"
               line="1255">the #GtkAboutDialog in which the user activated a link.</doc>
          <type name="Gtk.AboutDialog" c:type="GtkAboutDialog*"/>
        </parameter>
        <parameter name="address" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-gtk-extensions.c"
               line="1256">the link, mail or web address, to open.</doc>
          <type name="utf8" c:type="const gchar*"/>
        </parameter>
        <parameter name="user_data"
                   transfer-ownership="none"
                   nullable="1"
                   allow-none="1">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-gtk-extensions.c"
               line="1257">user data that was passed when the function was
                registered with gtk_about_dialog_set_email_hook()
                or gtk_about_dialog_set_url_hook(). This is currently
                unused within the context of this function, so you
                can safely pass %NULL when registering this hook
                with #GtkAboutDialog.</doc>
          <type name="gpointer" c:type="gpointer"/>
        </parameter>
      </parameters>
    </function>
    <function name="gtk_window_center_on_active_screen"
              c:identifier="xfce_gtk_window_center_on_active_screen">
      <doc xml:space="preserve"
           filename="libxfce4ui/xfce-gtk-extensions.c"
           line="834">Determines the screen that contains the pointer and centers the
@window on it. If it failes to determine the current pointer position,
@window is centered on the default screen.

This function only works properly if you call it before realizing the
window and you haven't set a fixed window position using gtk_window_move().

See also: xfce_gdk_screen_get_active().</doc>
      <source-position filename="libxfce4ui/xfce-gtk-extensions.h" line="195"/>
      <return-value transfer-ownership="none">
        <type name="none" c:type="void"/>
      </return-value>
      <parameters>
        <parameter name="window" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4ui/xfce-gtk-extensions.c"
               line="836">the #GtkWindow to center.</doc>
          <type name="Gtk.Window" c:type="GtkWindow*"/>
        </parameter>
      </parameters>
    </function>
    <function name="has_gtk_frame_extents"
              c:identifier="xfce_has_gtk_frame_extents"
              version="4.16">
      <doc xml:space="preserve"
           filename="libxfce4ui/xfce-gtk-extensions.c"
           line="1130">This function can be called to determine if a #GdkWindow is using client-side decorations
which is indicated by the _GTK_FRAME_EXTENTS X11 atom. It furthermore sets a pointer
of type #GtkBorder to the actual extents.</doc>
      <source-position filename="libxfce4ui/xfce-gtk-extensions.h" line="220"/>
      <return-value transfer-ownership="none">
        <doc xml:space="preserve"
             filename="libxfce4ui/xfce-gtk-extensions.c"
             line="1139">TRUE if a #GdkWindow has the _GTK_FRAME_EXTENTS atom set.</doc>
        <type name="gboolean" c:type="gboolean"/>
      </return-value>
      <parameters>
        <parameter name="window" transfer-ownership="none">
